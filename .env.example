# 이 파일을 복사해 .env 로 만들고 값을 채우세요(로컬 vercel dev 용).
# 배포(운영) 값은 Vercel 대시보드 → Project → Settings → Environment Variables 에 넣습니다.
# .env 는 .gitignore 로 커밋되지 않습니다. (실제 키를 깃에 올리지 마세요)

# ── Kakao 지도 (JavaScript 키) ──────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → "JavaScript 키"
# [플랫폼 > Web]에 배포 도메인(https://<프로젝트>.vercel.app)과
#   http://localhost:3000 (vercel dev) 을 반드시 등록해야 지도가 뜹니다.
# Kakao Maps 사용 설정(활성화)도 켜세요.
# 이 키는 클라이언트로 전달되는 공개키이며 도메인 제한으로 보호됩니다.
KAKAO_JS_KEY=

# ── Telegram 봇 (서버에서만 사용 — 절대 클라이언트에 노출 금지) ──
# 1) 텔레그램에서 @BotFather 와 대화 → /newbot → 안내따라 생성 → 토큰 복사
TELEGRAM_BOT_TOKEN=
# 2) 알림 받을 chat id (개인/그룹/채널)
#    - 봇과 먼저 대화(예: /start) 한 뒤
#    - https://api.telegram.org/bot<토큰>/getUpdates 를 열어 result[].message.chat.id 확인
#    - (그룹이면 봇을 그룹에 초대 후 메시지 보내고 동일하게 확인, 채널은 채널ID 사용)
TELEGRAM_CHAT_ID=
